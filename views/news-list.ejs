<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách bài viết</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h1>Danh sách bài viết</h1>
    <nav>
        <a href="/">Trang chủ</a> |
        <a href="/news">Các Món Ăn Mới</a>
        <% if (user) { %>
            | <a href="/foods">Thêm Các Món Ăn</a>
            | Xin chào, <%= user.username %> |
            <a href="/logout">Đăng xuất</a>
        <% } else { %>
            | <a href="/login">Đăng nhập</a>
        <% } %>
    </nav>

    <% if (posts && posts.length > 0) { %>
        <ul>
            <% posts.forEach(post => { %>
                <li>
                    <h3><%= post.title %></h3>
                    <p><%= post.description %></p>
                    <div>
                        <a href="/news/<%= post.id %>">Xem chi tiết</a>
                        <% if (user) { %>
                            | <a href="/news/<%= post.id %>/edit">Sửa</a>
                            | <form action="/news/<%= post.id %>/delete" method="POST" style="display:inline;">
                                <button type="submit" onclick="return confirm('Bạn chắc chắn muốn xóa?')">Xóa</button>
                            </form>
                        <% } %>
                    </div>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>Chưa có bài viết nào.</p>
    <% } %>
</body>
</html>
