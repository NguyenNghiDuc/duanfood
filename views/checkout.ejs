<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thanh toán</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
<main class="container">
  <section class="card">
    <h1>Thanh toán</h1>

    <nav>
      <a href="/">Trang chủ</a>
      <a href="/foods">Món ăn</a>
      <a href="/cart">Giỏ hàng (<%= cart.length %>)</a>
      <a href="/orders">Đơn hàng</a>
    </nav>

    <div class="checkout-layout">

      <!-- LEFT -->
      <section class="checkout-box">
        <h2>Thông tin thanh toán</h2>

        <% if (!cart || cart.length === 0) { %>
          <p>Giỏ hàng đang trống.</p>
          <a class="btn" href="/foods">Đi chọn món</a>
        <% } else { %>

          <% if (error) { %>
            <p class="notice"><%= error %></p>
          <% } %>

          <form method="POST" action="/checkout">
            <label>Phương thức thanh toán</label>

            <select name="paymentMethod" required>
              <option value="COD">Thanh toán khi nhận hàng (COD)</option>
              <option value="wallet">Thanh toán bằng ví</option>
              <option value="Banking">Chuyển khoản ngân hàng</option>
              <option value="Momo">Ví MoMo</option>
            </select>

            <button type="submit" class="btn">
              Xác nhận thanh toán
            </button>
          </form>

        <% } %>
      </section>

      <!-- RIGHT -->
      <aside class="cart-summary">
        <h2>Đơn hàng</h2>

        <p>
          <strong>Tổng tiền:</strong>
          <%= Number(total || 0).toLocaleString('vi-VN') %> ₫
        </p>

        <p>
          <strong>Số dư ví:</strong>
          <%= Number((user && user.balance) || 0).toLocaleString('vi-VN') %> ₫
        </p>

        <a class="btn" href="/wallet/top-up">Nạp tiền vào ví</a>

        <hr />

        <ul>
          <% (cart || []).forEach(item => { %>
            <li>
              <strong><%= item.title %></strong><br/>
              <%= item.quantity %> ×
              <%= Number(item.price).toLocaleString('vi-VN') %> ₫
            </li>
          <% }) %>
        </ul>
      </aside>

    </div>
  </section>
</main>
</body>
</html>