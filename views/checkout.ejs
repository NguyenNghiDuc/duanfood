<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thanh toán</title>
  <link rel="stylesheet" href="/css/checkout.css" />
</head>

<body>
<main class="container">
  <section class="card">
    <h1>Thanh toán</h1>

    <nav>
      <a href="/">Trang chủ</a>
      <a href="/foods">Món ăn</a>
      <a href="/cart">Giỏ hàng (<%= cart.length %>)</a>
      <a href="/orders">Đơn hàng</a>
    </nav>

    <div class="checkout-layout">

      <!-- LEFT -->
      <section class="checkout-box">
        <h2>Thông tin thanh toán</h2>

        <% if (!cart || cart.length === 0) { %>
          <p>Giỏ hàng đang trống.</p>
          <a class="btn" href="/foods">Đi chọn món</a>
        <% } else { %>

          <% if (error) { %>
            <p class="notice"><%= error %></p>
          <% } %>

          <form method="POST" action="/checkout">

            <label>Địa chỉ giao hàng</label>
            <% if (addresses && addresses.length) { %>
              <div class="address-select">
                <% addresses.forEach(address => { %>
                  <label class="address-option">
                    <input
                      type="radio"
                      name="addressId"
                      value="<%= address.id %>"
                      <%= String(address.id) === String(selectedAddressId) ? 'checked' : '' %>
                      required
                    />
                    <div>
                      <strong><%= address.label %></strong>
                      <% if (address.is_default) { %>
                        <span class="badge">Mặc định</span>
                      <% } %>
                      <p><%= address.full_name %> · <%= address.phone %></p>
                      <p><%= address.detail_address %>, <%= address.street %>, <%= address.ward %>, <%= address.district %>, <%= address.city %></p>
                    </div>
                  </label>
                <% }) %>
              </div>
              <p><a href="/profile/addresses">Quản lý địa chỉ</a></p>
            <% } else { %>
              <p>Chưa có địa chỉ giao hàng. <a href="/profile/addresses/add">Thêm địa chỉ</a> trước khi đặt hàng.</p>
            <% } %>

            <label>Đơn vị vận chuyển</label>
           <div class="shipping-options">
              <% deliveryCompanies.forEach(company => { %>
              <label class="shipping-card">
                 <input
                type="radio"
                    name="deliveryCompanyId"
                 value="<%= company.id %>"
                required
             />
             <div class="shipping-info">
              <strong><%= company.name %></strong>
             <span>
               Phí ship:
               <%= Number(company.fee).toLocaleString('vi-VN') %> ₫
             </span>
             </div>
            </label>
            <% }) %>
             </div>
            </select>

            <label>Phương thức thanh toán</label>
            <select name="paymentMethod" required>
              <option value="COD">Thanh toán khi nhận hàng (COD)</option>
              <option value="wallet">Thanh toán bằng ví</option>
              <option value="Banking">Chuyển khoản ngân hàng</option>
              <option value="Momo">Ví MoMo</option>
            </select>

            <button type="submit" class="btn" <%= !(addresses && addresses.length) ? 'disabled' : '' %>>
              Xác nhận thanh toán
            </button>
          </form>

        <% } %>
      </section>

      <!-- RIGHT -->
      <aside class="cart-summary">
        <h2>Đơn hàng</h2>

        <p>
          <strong>Tổng tiền:</strong>
          <%= Number(total || 0).toLocaleString('vi-VN') %> ₫
        </p>

        <p>
          <strong>Số dư ví:</strong>
          <%= Number((user && user.balance) || 0).toLocaleString('vi-VN') %> ₫
        </p>

        <a class="btn" href="/wallet/top-up">Nạp tiền vào ví</a>

        <hr />

        <ul>
          <% (cart || []).forEach(item => { %>
            <li>
              <strong><%= item.title %></strong><br/>
              <%= item.quantity %> ×
              <%= Number(item.price).toLocaleString('vi-VN') %> ₫
            </li>
          <% }) %>
        </ul>
      </aside>

    </div>
  </section>
</main>
</body>
</html>