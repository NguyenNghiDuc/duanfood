<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= food.title %></title>
    <link rel="stylesheet" href="/css/food-detail.css">
</head>
<body>
<main class="food-detail-page">
    <nav class="detail-nav">
        <a href="/">Trang chủ</a>
        <a href="/foods">Món ăn</a>
        <a href="/addresses">Địa chỉ</a>
        <% if (user) { %>
            <% if (user.role === 'admin') { %>
                <a href="/admin/categories">Quản lý danh mục</a>
            <% } %>
            <a href="/logout">Đăng xuất</a>
        <% } else { %>
            <a href="/login">Đăng nhập</a>
            <a href="/register">Đăng ký</a>
        <% } %>
    </nav>

    <section class="food-detail-card">
        <div class="food-detail-image">
            <% if (food.image) { %>
                <img src="<%= food.image %>" alt="<%= food.title %>">
            <% } else { %>
                <img src="/images/default-food.jpg" alt="<%= food.title %>">
            <% } %>
        </div>

        <div class="food-detail-content">
            <h1><%= food.title %></h1>
            <p class="food-detail-category"><strong>Danh mục:</strong> <%= food.category_name || 'Chưa phân loại' %></p>
            <p class="food-detail-price"><strong>Giá:</strong> <%= Number(food.price).toLocaleString('vi-VN') %> ₫</p>
            <p class="food-detail-description"><%= food.description %></p>

            <div class="food-detail-actions">
                <form method="POST" action="/cart/add/<%= food.id %>">
                    <button type="submit" class="btn">Thêm vào giỏ</button>
                </form>
            </div>
        </div>
    </section>

    <section class="reviews-section">
        <h2>Đánh giá</h2>
        <p><strong>Số đánh giá:</strong> <%= ratingSummary.reviewCount %></p>
        <p><strong>Điểm trung bình:</strong> <%= ratingSummary.avgRating ? ratingSummary.avgRating.toFixed(1) : '0.0' %> / 5</p>

        <% if (user) { %>
            <form method="POST" action="/foods/<%= food.id %>/review" class="review-form">
                <label>Chọn số sao</label>
                <select name="rating" required>
                    <option value="5">5</option>
                    <option value="4">4</option>
                    <option value="3">3</option>
                    <option value="2">2</option>
                    <option value="1">1</option>
                </select>
                <label>Bình luận</label>
                <textarea name="comment" rows="4" placeholder="Viết nhận xét của bạn"></textarea>
                <button type="submit" class="btn">Gửi đánh giá</button>
            </form>
        <% } else { %>
            <p>Bạn cần <a href="/login">đăng nhập</a> để viết đánh giá.</p>
        <% } %>

        <div class="review-list">
            <% if (reviews && reviews.length) { %>
                <% reviews.forEach(review => { %>
                    <article class="review-card">
                        <strong><%= review.username %></strong>
                        <span><%= '★'.repeat(review.rating) %></span>
                        <p><%= review.comment || '' %></p>
                    </article>
                <% }) %>
            <% } else { %>
                <p>Chưa có đánh giá nào cho món này.</p>
            <% } %>
        </div>
    </section>
</main>
</body>
</html>