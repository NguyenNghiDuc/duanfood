<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= food.title %></title>
    <link rel="stylesheet" href="/css/food-detail.css">
</head>
<body>

<div class="food-detail-container">

    <div class="detail-nav">
        <a href="/"> Trang chủ</a>
        <a href="/foods"> Thực đơn</a>
    </div>
    <div class="food-detail-image">
            <% if(food.image){ %>
                <img src="<%= food.image %>" alt="<%= food.title %>">
            <% } else { %>
                <img src="/images/default-food.jpg" alt="Food">
            <% } %>
        </div>

    <% if (food) { %>

    <div class="food-detail-card">

        <div class="food-detail-content">
            <h1><%= food.title %></h1>

            <span class="category-badge">
                <%= food.category_name || 'Chưa phân loại' %>
            </span>

            <p class="food-description">
                <%= food.description %>
            </p>

            <div class="food-price">
                <%= Number(food.price).toLocaleString('vi-VN') %> ₫
            </div>

            <form method="POST" action="/cart/add/<%= food.id %>">
                <button type="submit" class="add-cart-btn">
                     Thêm vào giỏ hàng
                </button>
            </form>

                        <% if (user) { %>
                            <form method="POST" action="/foods/<%= food.id %>/review" class="review-form">
                                <label>Đánh giá</label>
                                <select name="rating" required>
                                    <% for (let i = 5; i >= 1; i--) { %>
                                        <option value="<%= i %>"><%= i %> sao</option>
                                    <% } %>
                                </select>
                                <textarea name="comment" rows="4" placeholder="Viết nhận xét..."></textarea>
                                <button type="submit" class="btn">Gửi đánh giá</button>
                            </form>
                        <% } else { %>
                            <p><a href="/login">Đăng nhập</a> để đánh giá món ăn.</p>
                        <% } %>

                        <% if (reviews && reviews.length) { %>
                            <div class="review-summary">
                                <strong>Điểm trung bình:</strong> <%= ratingSummary.avgRating.toFixed(1) %> / 5 (
                                <%= ratingSummary.reviewCount %> đánh giá)
                            </div>
                            <div class="review-list">
                                <% reviews.forEach(review => { %>
                                    <div class="review-card">
                                        <p><strong><%= review.username %></strong> - <%= review.rating %> sao</p>
                                        <p><%= review.comment %></p>
                                        <p class="small"> <%= new Date(review.created_at).toLocaleString('vi-VN') %></p>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>

            <a href="/foods" class="back-btn">
                ← Quay lại danh sách món ăn
            </a>
        </div>

    </div>

    <% } else { %>

    <div class="food-not-found">
        <h2>Không tìm thấy món ăn</h2>
        <a href="/foods">Quay lại thực đơn</a>
    </div>

    <% } %>

</div>

</body>
</html>