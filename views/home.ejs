<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Food</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <header class="topbar">

        <div class="container topbar-inner">

            <a href="/" class="brand">
                <img src="/images/anh.png" class="brand-logo">
                <span class="brand-text">
                    Mini Food
                </span>
            </a>
            <div class="topbar-links">
                <% if(user){ %>
                    <a href="/profile">
                        <%= user.username %>
                    </a>
                    <a href="/orders">  Đơn hàng</a>
                    <a href="/logout"> Đăng xuất</a>

                <% } else { %>

                    <a href="/login">Đăng nhập </a>

                    <a href="/register">  Đăng ký</a>

                <% } %>

                <a href="/cart">
                    Giỏ hàng
                </a>
                <a href="/wallet"> Nạp tiền</a>

            </div>

        </div>

    </header>


    <main class="container">

        <nav class="main-nav">

            <a href="/">Trang chủ</a>

            <a href="/about">
                Giới thiệu
            </a>

            <a href="/foods">
                Món ăn
            </a>

            <a href="/promotion">
                Khuyến mãi
            </a>

            <a href="/contact">
                Liên hệ
            </a>

        </nav>


        <section class="hero-grid">

            <article>

                <span class="badge">
                    FAST FOOD
                </span>

                <h1>
                    Đặt món ăn nhanh chóng
                </h1>

                <p>
                    Khám phá các món ăn nổi bật và trải nghiệm đặt món tiện lợi.
                </p>

                <div class="cta-row">

                    <a class="btn" href="/foods">
                        Đặt ngay
                    </a>

                    <a class="btn btn-secondary" href="/promotion">
                        Xem ưu đãi
                    </a>

                </div>

            </article>

            <aside class="banner-stack">

                <div class="mini-banner">
                    BURGER
                </div>

                <div class="mini-banner">
                    PIZZA
                </div>

                <div class="mini-banner">
                    GÀ RÁN
                </div>

            </aside>

        </section>


        <section class="card">

            <h2>
                Khuyến mãi
            </h2>

            <div class="promo-grid">

                <div class="promo-card">
                    Giảm giá 50%
                </div>

                <div class="promo-card">
                    Mua 2 tặng 1
                </div>

                <div class="promo-card">
                    Miễn phí vận chuyển
                </div>

            </div>

        </section>


        <section class="card">

            <h2>
                Danh mục món ăn
            </h2>

            <div class="category-grid">

                <% if(categories && categories.length){ %>

                    <% categories.forEach(category=>{ %>

                        <a
                            class="category-card"
                            href="/foods?category=<%= encodeURIComponent(category.name) %>"
                        >

                            <strong>
                                <%= category.name %>
                            </strong>

                            <!-- removed "Xem thêm" as requested -->

                        </a>

                    <% }) %>

                <% } %>

            </div>

        </section>


        <section class="card">

            <h2>
                Sản phẩm nổi bật
            </h2>

            <div class="product-grid">

                <% if(foods && foods.length){ %>

                    <% foods.forEach(food=>{ %>

                        <article class="product-card">

                            <% if(food.image){ %>

                                <img
                                    src="<%= food.image %>"
                                    alt="<%= food.title %>"
                                >

                            <% } %>

                            <h3>
                                <%= food.title %>
                            </h3>

                            <p>
                                <%= food.description %>
                            </p>

                            <div class="product-meta">

                                <strong>
                                    <%= Number(food.price).toLocaleString("vi-VN") %> đ
                                </strong>

                                <form
                                    method="POST"
                                    action="/cart/add/<%= food.id %>"
                                >

                                    <button class="btn">
                                        Thêm vào giỏ
                                    </button>

                                </form>

                            </div>

                        </article>

                    <% }) %>

                <% } %>

            </div>

        </section>

    </main>
    <footer class="footer">

        <div class="container footer-grid">

            <div>
                <h3>Địa chỉ</h3>

                <p>Dương Nội - Hà Đông</p>

            </div>

            <div>

                <h3> Hotline</h3>
                <p>0909 999 999</p>
            </div>
            <div>
                <h3>Email</h3>
                <p>support@minifood.vn</p>
            </div>
            <div>
                <h3> FaceBook</h3>
                <p> FOOD </p>
            </div>
        </div>
    </footer>
</body>

</html>