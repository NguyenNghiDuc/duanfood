<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thêm món ăn</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="admin-page">
    <section class="card admin-card">
      <div class="admin-header">
        <div>
          <h1>Thêm món ăn mới</h1>
          <p>Nhập thông tin món ăn và dán đường dẫn ảnh trực tiếp để hiện trên trang.</p>
        </div>

        <div class="admin-actions">
          <a href="/foods" class="btn btn-secondary">
            Quay lại danh sách
          </a>
        </div>
      </div>

      <nav class="admin-breadcrumb">
        <a href="/">Trang chủ</a>
        <span>›</span>
        <a href="/foods">Món ăn</a>
        <span>›</span>
        <span>Thêm món ăn</span>
      </nav>

      <form
        method="POST"
        action="/admin/foods/add"
        class="form-grid admin-form"
        id="add-food-form"
      >
        <label>
          Tiêu đề món ăn
          <input
            type="text"
            name="title"
            required
          />
        </label>

        <label>
          Giá bán (₫)
          <input
            type="text"
            name="price"
            id="price-input"
            inputmode="numeric"
            autocomplete="off"
            placeholder="1.000"
            required
          />
          <small>
            Nhập số và hệ thống sẽ tự thêm dấu chấm cho hàng nghìn.
          </small>
        </label>

        <label>
          Danh mục
          <select name="category_id">
            <option value="1">Đồ ăn</option>
            <option value="2">Đồ uống</option>
            <option value="3">Tráng miệng</option>
            <option value="4">Đồ dùng trong nhà</option>
            <option value="5">Đồ dùng nấu ăn</option>
          </select>
        </label>

        <label>
          URL ảnh món ăn
          <input
            type="text"
            name="image"
            placeholder="https://..."
          />
          <small>
            Không cần upload, dùng link ảnh trực tiếp hoặc đường dẫn local như /images/tenfile.png
          </small>
        </label>

        <label>
          Mô tả món ăn
          <textarea
            name="description"
            rows="5"
            required
          ></textarea>
        </label>

        <button
          type="submit"
          class="btn"
        >
          Lưu món ăn
        </button>
      </form>
    </section>
  </main>

  <script>
    const priceInput = document.getElementById('price-input')
    const addFoodForm = document.getElementById('add-food-form')

    function formatPrice(value) {
      const digits = String(value || '').replace(/\D/g, '')
      return digits.replace(/\B(?=(\d{3})+(?!\d))/g, '.')
    }

    priceInput.addEventListener('input', () => {
      priceInput.value = formatPrice(priceInput.value)
    })

    addFoodForm.addEventListener('submit', () => {
      priceInput.value = priceInput.value.replace(/\./g, '')
    })
  </script>
</body>
</html>